{
  "identifier": "default",
  "description": "Default capabilities for Promptcase",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "promptcase-sidecar",
          "sidecar": true,
          "args": []
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "promptcase-sidecar",
          "sidecar": true,
          "args": []
        }
      ]
    }
  ]
}
